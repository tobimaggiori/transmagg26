  mesAnio    String   @unique @map("mes_anio")
  pdfS3Key   String?  @map("pdf_s3_key")
  generadoEn DateTime @default(now()) @map("generado_en")
  operadorId String   @map("operador_id")

  operador   Usuario  @relation("OperadorLibroPercepciones", fields: [operadorId], references: [id])

  @@map("libros_percepciones")
}

// ─── NOTAS DE CRÉDITO / DÉBITO ────────────────────────────────────────────────

model NotaCreditoDebito {
  id                  String    @id @default(uuid())
  tipo                String
  // NC_EMITIDA | ND_EMITIDA | NC_RECIBIDA | ND_RECIBIDA
  subtipo             String?   @map("subtipo")
  // NC_EMITIDA subtipos: ANULACION_TOTAL | ANULACION_PARCIAL | CORRECCION_IMPORTE
  // ND_EMITIDA subtipos: DIFERENCIA_TARIFA | COSTO_ADICIONAL | AJUSTE | PENALIDAD | CORRECCION_ADMINISTRATIVA
  // NC_RECIBIDA subtipos: (NC/ND sobre LP bloqueadas en esta etapa)
  // ND_RECIBIDA subtipos: CHEQUE_RECHAZADO

  facturaId           String?   @map("factura_id")
  liquidacionId       String?   @map("liquidacion_id")
  chequeRecibidoId    String?   @map("cheque_recibido_id")

  nroComprobanteExterno   String?   @map("nro_comprobante_externo")
  fechaComprobanteExterno DateTime? @map("fecha_comprobante_externo")
  emisorExterno           String?   @map("emisor_externo")

  montoNeto           Decimal     @map("monto_neto")
  montoIva            Decimal     @default(0) @map("monto_iva")
  montoTotal          Decimal     @map("monto_total")

  descripcion         String?
  motivoDetalle       String?   @map("motivo_detalle")

  estado              String    @default("EMITIDA")

  nroComprobante      Int?      @map("nro_comprobante")
  ptoVenta            Int?      @default(1) @map("pto_venta")
  tipoCbte            Int?      @map("tipo_cbte")
  cae                 String?   @map("cae")
  caeVto              DateTime? @map("cae_vto")
  qrData              String?   @map("qr_data")
  arcaEstado          String?   @default("PENDIENTE") @map("arca_estado")
  arcaObservaciones   String?   @map("arca_observaciones")
  requestArcaJson     String?   @map("request_arca_json")
  // Payload enviado a ARCA (serializado como JSON string)
  responseArcaJson    String?   @map("response_arca_json")
  // Respuesta de ARCA (serializada como JSON string)
  autorizadaEn        DateTime? @map("autorizada_en")
  // Timestamp de autorización exitosa en ARCA
  idempotencyKey      String?   @map("idempotency_key")
  // UUID para prevenir doble emisión
  // Comprobante asociado para NC/ND (requerido por ARCA)
  cbteAsocTipo        Int?      @map("cbte_asoc_tipo")
  cbteAsocPtoVta      Int?      @map("cbte_asoc_pto_vta")
  cbteAsocNro         Int?      @map("cbte_asoc_nro")

  pdfS3Key            String?   @map("pdf_s3_key")

  operadorId          String    @map("operador_id")
  creadoEn            DateTime  @default(now()) @map("creado_en")

  factura             FacturaEmitida?   @relation(fields: [facturaId], references: [id], onDelete: SetNull)
  liquidacion         Liquidacion?      @relation(fields: [liquidacionId], references: [id], onDelete: SetNull)
  chequeRecibido      ChequeRecibido?   @relation(fields: [chequeRecibidoId], references: [id], onDelete: SetNull)
  operador            Usuario           @relation("OperadorNotaCreditoDebito", fields: [operadorId], references: [id])
  viajesAfectados     ViajeEnNotaCD[]
  items               NotaCreditoDebitoItem[]

  @@map("notas_credito_debito")
}

model ViajeEnNotaCD {
  id                String @id @default(uuid())
  notaId            String @map("nota_id")
  viajeId           String @map("viaje_id")
  tarifaOriginal    Decimal  @map("tarifa_original")
  kilosOriginal     Float? @map("kilos_original")
  subtotalOriginal  Decimal  @map("subtotal_original")
  subtotalCorregido Decimal? @map("subtotal_corregido")

  nota  NotaCreditoDebito @relation(fields: [notaId], references: [id], onDelete: Cascade)
  viaje Viaje             @relation(fields: [viajeId], references: [id])

  @@unique([notaId, viajeId])
  @@map("viajes_en_nota_cd")
}

model NotaCreditoDebitoItem {
  id       String  @id @default(uuid())
  notaId   String  @map("nota_id")
  orden    Int
  concepto String
  subtotal Decimal

  nota NotaCreditoDebito @relation(fields: [notaId], references: [id], onDelete: Cascade)

  @@map("notas_cd_items")
}

// ─── NEXTAUTH ─────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user NextAuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user NextAuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model NextAuthUser {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?

  accounts Account[]
  sessions Session[]

  @@map("nextauth_users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── ORDEN DE PAGO ────────────────────────────────────────────────────────────

model OrdenPago {
