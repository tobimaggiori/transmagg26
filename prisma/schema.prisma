  @@map("sessions")
}

model NextAuthUser {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?

  accounts Account[]
  sessions Session[]

  @@map("nextauth_users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── ORDEN DE PAGO ────────────────────────────────────────────────────────────

model OrdenPago {
  id         String   @id @default(uuid())
  nro        Int // correlativo por (fleteroId, anio)
  anio       Int // año calendario de emisión, ej. 2026
  fecha      DateTime @default(now())
  fleteroId  String   @map("fletero_id")
  pdfS3Key   String?  @map("pdf_s3_key")
  operadorId String   @map("operador_id")
  creadoEn   DateTime @default(now()) @map("creado_en")

  fletero  Fletero        @relation(fields: [fleteroId], references: [id])
  operador Usuario        @relation("OperadorOrdenPago", fields: [operadorId], references: [id])
  pagos    PagoAFletero[]

  @@unique([fleteroId, nro, anio])
  @@map("ordenes_pago")
}

// ─── ASEGURADORAS ─────────────────────────────────────────────────────────────

model FacturaSeguro {
  id               String   @id @default(uuid())
  aseguradoraId    String   @map("aseguradora_id")
  nroComprobante   String   @map("nro_comprobante")
  tipoComprobante  String   @default("A") @map("tipo_comprobante")
  fecha            DateTime
  periodoDesde     DateTime @map("periodo_desde")
  periodoHasta     DateTime @map("periodo_hasta")
  neto             Decimal
  iva              Decimal
  total            Decimal
  formaPago        String   @map("forma_pago")
  medioPagoContado String?  @map("medio_pago_contado")
  cuentaId         String?  @map("cuenta_id")
  tarjetaId        String?  @map("tarjeta_id")
  cantCuotas       Int?     @map("cant_cuotas")
  montoCuota       Decimal? @map("monto_cuota")
  estadoPago       String   @default("PENDIENTE") @map("estado_pago")
  operadorId       String   @map("operador_id")
  creadoEn         DateTime @default(now()) @map("creado_en")

  aseguradora  Proveedor            @relation("AseguradoraFacturasSeguro", fields: [aseguradoraId], references: [id])
  cuenta       Cuenta?              @relation("CuentaFacturaSeguro", fields: [cuentaId], references: [id])
  tarjeta      Tarjeta?             @relation("TarjetaFacturaSeguro", fields: [tarjetaId], references: [id])
  operador     Usuario              @relation("OperadorFacturaSeguro", fields: [operadorId], references: [id])
  polizas      PolizaSeguro[]
  cuotas       CuotaFacturaSeguro[]
  asientosIva  AsientoIva[]         @relation("FacturaSeguroAsientoIva")
  percepciones PercepcionImpuesto[]
  items        ItemFacturaSeguro[]

  @@map("facturas_seguro")
}

model ItemFacturaSeguro {
  id              String   @id @default(uuid())
  facturaSeguroId String   @map("factura_seguro_id")
  orden           Int
  tipo            String // CONCEPTO | IVA | PERCEPCION | IMPUESTO
  subtipo         String? // PERCEPCION_IVA | PERCEPCION_IIBB | PERCEPCION_GANANCIAS | PERCEPCION_SUSS | OTRO (solo si tipo=PERCEPCION)
  descripcion     String
  alicuota        Float?
  baseCalculo     Decimal? @map("base_calculo")
  monto           Decimal

  factura FacturaSeguro @relation(fields: [facturaSeguroId], references: [id], onDelete: Cascade)

  @@index([facturaSeguroId])
  @@map("items_factura_seguro")
}

model CuotaFacturaSeguro {
  id               String   @id @default(uuid())
  facturaSeguroId  String   @map("factura_seguro_id")
  tarjetaId        String   @map("tarjeta_id")
  nroCuota         Int      @map("nro_cuota")
  totalCuotas      Int      @map("total_cuotas")
  monto            Decimal
  mesAnio          String   @map("mes_anio")
  estado           String   @default("PENDIENTE")
  resumenTarjetaId String?  @map("resumen_tarjeta_id")
  creadoEn         DateTime @default(now()) @map("creado_en")

  facturaSeguro  FacturaSeguro   @relation(fields: [facturaSeguroId], references: [id], onDelete: Cascade)
  tarjeta        Tarjeta         @relation("TarjetaCuotasSeguro", fields: [tarjetaId], references: [id])
  resumenTarjeta ResumenTarjeta? @relation("ResumenCuotasSeguro", fields: [resumenTarjetaId], references: [id])

  @@map("cuotas_facturas_seguro")
}

// ─── HISTORIAL DE PAGOS ───────────────────────────────────────────────────────
// tipoEvento: CREACION | MODIFICACION | ANULACION

// ─── CONFIGURACIÓN ARCA ───────────────────────────────────────────────────────

model ConfiguracionArca {
  id                      String   @id @default("unico")
  cuit                    String   @default("30709381683")
  razonSocial             String   @default("") @map("razon_social")
  certificadoB64          String?  @map("certificado_b64")
  certificadoPass         String?  @map("certificado_pass")
  modo                    String   @default("homologacion")
  puntosVenta             String   @default("{}") @map("puntos_venta")
  comprobantesHabilitados String   @default("[]") @map("comprobantes_habilitados")
  cbuMiPymes              String?  @map("cbu_mi_pymes")
  montoMinimoFce          Decimal? @map("monto_minimo_fce") @db.Decimal(15, 2)
  activa                  Boolean  @default(false)
  logoComprobanteB64      String?  @map("logo_comprobante_b64")
  logoArcaB64             String?  @map("logo_arca_b64")
  logoComprobanteR2Key    String?  @map("logo_comprobante_r2_key")
  logoArcaR2Key           String?  @map("logo_arca_r2_key")
  actualizadoEn           DateTime @updatedAt @map("actualizado_en")
  actualizadoPor          String?  @map("actualizado_por")

  @@map("configuracion_arca")
}

// Cache del ticket de acceso WSAA para evitar autenticar en cada request.
// El ticket dura 12 horas; se renueva automáticamente al expirar.
model TicketWsaa {
  id         String   @id @default("wsfe")
  // "wsfe" para WSFEv1. Extensible a otros servicios si se necesita.
  token      String
  sign       String
  expiresAt  DateTime @map("expires_at")
  // Momento de expiración del ticket (generationTime + 12h de WSAA)
  obtainedAt DateTime @default(now()) @map("obtained_at")
  // Momento en que se obtuvo este ticket

  @@map("tickets_wsaa")
}

model HistorialPago {
  id              String   @id @default(uuid())
  pagoFleteroId   String?  @map("pago_fletero_id")
  pagoProveedorId String?  @map("pago_proveedor_id")
  tipoEvento      String   @map("tipo_evento") // CREACION | MODIFICACION | ANULACION
  justificacion   String
  estadoAnterior  String?  @map("estado_anterior") // JSON con los campos que cambiaron
  operadorId      String   @map("operador_id")
  creadoEn        DateTime @default(now()) @map("creado_en")

  pagoFletero   PagoAFletero?  @relation(fields: [pagoFleteroId], references: [id])
  pagoProveedor PagoProveedor? @relation(fields: [pagoProveedorId], references: [id])
  operador      Usuario        @relation("OperadorHistorialPago", fields: [operadorId], references: [id])

  @@map("historial_pagos")
}

// ─── RECIBOS DE COBRANZA ──────────────────────────────────────────────────────

model ReciboCobranza {
  id                 String   @id @default(uuid())
  nro                Int
  ptoVenta           Int      @default(1) @map("pto_venta")
  fecha              DateTime @default(now())
  empresaId          String   @map("empresa_id")
  totalCobrado       Decimal  @map("total_cobrado")
  totalRetenciones   Decimal  @default(0) @map("total_retenciones")
  totalComprobantes  Decimal  @map("total_comprobantes")
  retencionGanancias Decimal  @default(0) @map("retencion_ganancias")
  retencionIIBB      Decimal  @default(0) @map("retencion_iibb")
  retencionSUSS      Decimal  @default(0) @map("retencion_suss")
  totalFaltantes     Decimal  @default(0) @map("total_faltantes")
  saldoACuenta       Decimal  @default(0) @map("saldo_a_cuenta")
  pdfS3Key           String?  @map("pdf_s3_key")
  operadorId         String   @map("operador_id")
  creadoEn           DateTime @default(now()) @map("creado_en")

  empresa          Empresa           @relation(fields: [empresaId], references: [id])
  operador         Usuario           @relation("OperadorRecibo", fields: [operadorId], references: [id])
  facturasEnRecibo FacturaEnRecibo[]
  notasAplicadas   NotaAplicadaEnRecibo[]
  mediosPago       MedioPagoRecibo[]
  chequesRecibidos ChequeRecibido[]  @relation("ChequesRecibo")
  faltantes        FaltanteViaje[]

  @@map("recibos_cobranza")
}

model FacturaEnRecibo {
  id            String  @id @default(uuid())
  reciboId      String  @map("recibo_id")
  facturaId     String  @map("factura_id")
  montoAplicado Decimal @map("monto_aplicado")

  recibo  ReciboCobranza @relation(fields: [reciboId], references: [id])
  factura FacturaEmitida @relation(fields: [facturaId], references: [id])

  @@unique([reciboId, facturaId])
  @@map("facturas_en_recibo")
}

model FaltanteViaje {
  id                     String   @id @default(uuid())
  reciboCobranzaId       String   @map("recibo_cobranza_id")
  viajeId                String   @map("viaje_id")
  fleteroId              String   @map("fletero_id")
  empresaId              String   @map("empresa_id")
  monto                  Decimal
  descripcion            String?
  descontado             Boolean  @default(false)
  liquidacionDescuentoId String?  @map("liquidacion_descuento_id")
  creadoEn               DateTime @default(now()) @map("creado_en")

  recibo      ReciboCobranza @relation(fields: [reciboCobranzaId], references: [id])
  viaje       Viaje          @relation(fields: [viajeId], references: [id])
  fletero     Fletero        @relation(fields: [fleteroId], references: [id])
  empresa     Empresa        @relation(fields: [empresaId], references: [id])
  liquidacion Liquidacion?   @relation(fields: [liquidacionDescuentoId], references: [id])

  @@map("faltantes_viaje")
}

model MedioPagoRecibo {
  id                 String    @id @default(uuid())
  reciboId           String    @map("recibo_id")
  tipo               String // TRANSFERENCIA | ECHEQ | CHEQUE_FISICO | EFECTIVO | SALDO_CTA_CTE
  monto              Decimal
  cuentaId           String?   @map("cuenta_id")
  fechaTransferencia DateTime? @map("fecha_transferencia")
  referencia         String?
  nroCheque          String?   @map("nro_cheque")
  bancoEmisor        String?   @map("banco_emisor")
  fechaEmision       DateTime? @map("fecha_emision")
  fechaPago          DateTime? @map("fecha_pago")

  recibo ReciboCobranza @relation(fields: [reciboId], references: [id])

  @@map("medios_pago_recibo")
}

// ─── CONFIGURACIÓN OTP ────────────────────────────────────────────────────────

model FeriadoArgentino {
  fecha  DateTime @id @db.Date
  year   Int
  nombre String
  tipo   String

  @@index([year])
  @@map("feriados_argentinos")
}

model ConfiguracionEnvio {
  id            String   @id @default("singleton")
  replyTo       String?  @map("reply_to")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  @@map("configuracion_envio")
}
