  brokerOrigen          Broker?             @relation("BrokerOrigenChequeRecibido", fields: [brokerOrigenId], references: [id])
  factura               FacturaEmitida?     @relation(fields: [facturaId], references: [id], onDelete: SetNull)
  reciboCobranza        ReciboCobranza?     @relation("ChequesRecibo", fields: [reciboCobranzaId], references: [id], onDelete: SetNull)
  cuentaDeposito        Cuenta?             @relation("CuentaDepositaChequeRecibido", fields: [cuentaDepositoId], references: [id], onDelete: SetNull)
  endosadoAFletero      Fletero?            @relation("FleteroEndosoChequeRecibido", fields: [endosadoAFleteroId], references: [id], onDelete: SetNull)
  endosadoAProveedor    Proveedor?          @relation("ProveedorEndosoChequeRecibido", fields: [endosadoAProveedorId], references: [id], onDelete: SetNull)
  endosadoABroker       Cuenta?             @relation("CuentaBrokerChequeRecibido", fields: [endosadoABrokerId], references: [id], onDelete: SetNull)
  operador              Usuario             @relation("OperadorChequeRecibido", fields: [operadorId], references: [id])
  pagosEmpresa          PagoDeEmpresa[]
  pagosFletero          PagoAFletero[]
  pagosProveedor        PagoProveedor[]  @relation("ChequeRecibidoPagoProveedor")
  adelantos             AdelantoFletero[]
