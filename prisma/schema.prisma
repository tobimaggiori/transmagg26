  resumenTarjeta ResumenTarjeta? @relation("ResumenCuotasSeguro", fields: [resumenTarjetaId], references: [id])

  @@map("cuotas_facturas_seguro")
}

// ─── CIERRE RESUMEN TARJETA ──────────────────────────────────────────────────
// estadoPago factura: PENDIENTE | PENDIENTE_TARJETA | PAGADA_PARCIAL | PAGADA

model CierreResumenTarjeta {
