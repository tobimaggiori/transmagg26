generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS (documentados como String en SQLite) ────────────────────────────────
// GastoFletero.estado:         PENDIENTE_PAGO | PAGADO | DESCONTADO_PARCIAL | DESCONTADO_TOTAL
// GastoFletero.tipo:           COMBUSTIBLE | OTRO
// Rol:                         ADMIN_TRANSMAGG | OPERADOR_TRANSMAGG | FLETERO | CHOFER | ADMIN_EMPRESA | OPERADOR_EMPRESA
// Canal OTP:                   EMAIL | SMS
// Estado viaje:                PENDIENTE | EN_LIQUIDACION | EN_FACTURA | COMPLETO
// Estado liquidación:          EMITIDA | PARCIALMENTE_PAGADA | PAGADA  (inmutable, corrección por NC/ND)
// Estado factura:              EMITIDA | PARCIALMENTE_COBRADA | COBRADA  (inmutable, corrección por NC/ND)
// Estado ARCA:                 PENDIENTE | ACEPTADA | RECHAZADA
// Tipo pago fletero:           CHEQUE_PROPIO | CHEQUE_TERCERO | TRANSFERENCIA | EFECTIVO | ADELANTO
// Tipo pago empresa:           CHEQUE | TRANSFERENCIA | EFECTIVO
// Tipo IVA:                    VENTA | COMPRA
// Tipo cbte:                   A | B | C | M | X | LIQ_PROD
// Condición IVA:               RESPONSABLE_INSCRIPTO | MONOTRIBUTISTA | EXENTO | CONSUMIDOR_FINAL
// Tipo cuenta:                 BANCO | BILLETERA_VIRTUAL | BROKER
// Moneda cuenta/FCI:           PESOS | DOLARES | OTRO
// Formato reconciliación:      PDF | EXCEL | AMBOS
// Tipo movimiento FCI:         SUSCRIPCION | RESCATE
// Tipo MovimientoCuenta:        INGRESO | EGRESO
// Categoria MovimientoCuenta:   CHEQUE_DEPOSITADO | CHEQUE_EMITIDO_DEBITADO | TRANSFERENCIA_RECIBIDA |
//                               TRANSFERENCIA_ENVIADA | TRANSFERENCIA_ENTRE_CUENTAS_PROPIAS | ENVIO_A_BROKER |
//                               RESCATE_DE_BROKER | INTERES_CUENTA_REMUNERADA | PAGO_SERVICIO |
//                               MANTENIMIENTO_CUENTA | PAGO_TARJETA | DESCUENTO_CHEQUE_BANCO |
//                               PAGO_SUELDO | PAGO_FLETERO | PAGO_PROVEEDOR | COBRO_EMPRESA |
//                               PAGO_IMPUESTO | PAGO_INFRACCION | SUSCRIPCION_FCI | RESCATE_FCI |
//                               AJUSTE_MANUAL | OTRO
// Estado cheque recibido:      EN_CARTERA | DEPOSITADO | ENDOSADO_FLETERO | ENDOSADO_PROVEEDOR |
//                               ENDOSADO_BROKER | DESCONTADO_BANCO | RECHAZADO
// Endosado a tipo:             FLETERO | PROVEEDOR | BROKER
// Tipo doc beneficiario:       CUIT | CUIL | CDI
// Motivo pago cheque emitido:  VARIOS | FACTURA | ORDEN_DE_PAGO | ALQUILER | EXPENSAS | SERVICIOS
// Cláusula cheque emitido:     A_LA_ORDEN | NO_A_LA_ORDEN
// Estado cheque emitido:       PENDIENTE_EMISION | EMITIDO | DEPOSITADO | RECHAZADO
// Estado planilla Galicia:     BORRADOR | DESCARGADA | PROCESADA
// Tipo gasto prepaga/tarjeta:  COMBUSTIBLE | PEAJE | COMIDA | ALOJAMIENTO | REPUESTO | LAVADO | OTRO
// Tipo tarjeta:                CREDITO | DEBITO | PREPAGA
// Titular tarjeta tipo:        EMPRESA | CHOFER | EMPLEADO
// Tipo adelanto fletero:       EFECTIVO | TRANSFERENCIA | CHEQUE_PROPIO | CHEQUE_TERCERO | COMBUSTIBLE
// Estado adelanto fletero:     PENDIENTE_DESCUENTO | DESCONTADO_PARCIAL | DESCONTADO_TOTAL
// Tipo pago proveedor:         TRANSFERENCIA | CHEQUE_PROPIO | CHEQUE_FISICO_TERCERO | CHEQUE_ELECTRONICO_TERCERO | TARJETA | EFECTIVO
// Estado pago factura prov.:   PENDIENTE | PARCIALMENTE_PAGADA | PAGADA
// Tipo gasto tarjeta (extra):  PAGO_PROVEEDOR

// ─── USUARIOS ─────────────────────────────────────────────────────────────────

model Usuario {
  id        String   @id @default(uuid())
  nombre    String
  apellido  String
  email     String?  @unique
  telefono  String?
  cuil      String?
  rol       String
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now()) @map("creado_en")

  smtpHost     String? @map("smtp_host")
  smtpPuerto   Int?    @map("smtp_puerto")
  smtpUsuario  String? @map("smtp_usuario")
  smtpPassword String? @map("smtp_password")
  smtpSsl      Boolean @default(true) @map("smtp_ssl")
  smtpActivo   Boolean @default(false) @map("smtp_activo")

  otpCodigos                  OtpCodigo[]
  empresaUsuarios             EmpresaUsuario[]
  fletero                     Fletero?                 @relation("FleteroUsuario")
  liquidacionesOpera          Liquidacion[]            @relation("OperadorLiquidacion")
  facturasOpera               FacturaEmitida[]         @relation("OperadorFactura")
  viajesOperador              Viaje[]                  @relation("OperadorViajes")
  movimientosFciOpera         MovimientoFci[]          @relation("OperadorMovimientoFci")
  saldosFciOpera              SaldoFci[]               @relation("OperadorSaldoFci")
  movimientosCuentaOpera      MovimientoCuenta[]       @relation("OperadorMovimientoCuenta")
  conciliacionesDiaOpera      ConciliacionDia[]        @relation("OperadorConciliacionDia")
  cierresMesCuentaOpera       CierreMesCuenta[]        @relation("OperadorCierreMesCuenta")
  chequesRecibidosOpera       ChequeRecibido[]         @relation("OperadorChequeRecibido")
  chequesEmitidosOpera        ChequeEmitido[]          @relation("OperadorChequeEmitido")
  gastosTarjetaPrepagaOpera   GastoTarjetaPrepaga[]    @relation("OperadorGastoTarjetaPrepaga")
  gastosTarjetaOpera          GastoTarjeta[]           @relation("OperadorGastoTarjeta")
  empleado                    Empleado?                @relation("EmpleadoUsuario")
  adelantosFleterosOpera      AdelantoFletero[]        @relation("OperadorAdelantoFletero")
  notasCreditoDebitoOpera     NotaCreditoDebito[]      @relation("OperadorNotaCreditoDebito")
  pagosEmpresaOpera           PagoDeEmpresa[]          @relation("OperadorPagoEmpresa")
  pagosFleterosOpera          PagoAFletero[]           @relation("OperadorPagoFletero")
  pagosProveedorOpera         PagoProveedor[]          @relation("OperadorPagoProveedor")
  resumenesTarjetaOpera       ResumenTarjeta[]         @relation("OperadorResumenTarjeta")
  conciliacionDiaTarjetaOpera ConciliacionDiaTarjeta[] @relation("OperadorConciliacionDiaTarjeta")
  historialPagosOpera         HistorialPago[]          @relation("OperadorHistorialPago")
  ordenesPagoOpera            OrdenPago[]              @relation("OperadorOrdenPago")
  recibosOpera                ReciboCobranza[]         @relation("OperadorRecibo")
  facturasSeguroOpera         FacturaSeguro[]          @relation("OperadorFacturaSeguro")
  permisos                    PermisoUsuario[]
  pagosImpuesto               PagoImpuesto[]           @relation("OperadorPagoImpuesto")
  infracciones                Infraccion[]             @relation("OperadorInfracciones")
  librosIva                   LibroIva[]               @relation("OperadorLibroIva")
  librosIIBB                  LibroIIBB[]              @relation("OperadorLibroIIBB")
  librosPercepciones          LibroPercepciones[]      @relation("OperadorLibroPercepciones")

  @@map("usuarios")
}

// ─── PERMISOS POR USUARIO ─────────────────────────────────────────────────────

model PermisoUsuario {
  id         String   @id @default(uuid())
  usuarioId  String   @map("usuario_id")
  seccion    String
  habilitado Boolean  @default(true)
  creadoEn   DateTime @default(now()) @map("creado_en")

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@unique([usuarioId, seccion])
  @@map("permisos_usuario")
}

// ─── OTP ──────────────────────────────────────────────────────────────────────

model OtpCodigo {
  id         String   @id @default(uuid())
  usuarioId  String   @map("usuario_id")
  codigoHash String   @map("codigo_hash")
  canal      String
  expiraEn   DateTime @map("expira_en")
  usado      Boolean  @default(false)

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("otp_codigos")
}

// ─── EMPRESAS ─────────────────────────────────────────────────────────────────

model Empresa {
  id           String  @id @default(uuid())
  razonSocial  String  @map("razon_social")
  cuit         String  @unique
  condicionIva String  @map("condicion_iva")
  direccion    String?
  padronFce    Boolean @default(false) @map("padron_fce")
  activa       Boolean @default(true)

  empresaUsuarios  EmpresaUsuario[]
  facturasEmitidas FacturaEmitida[]
  viajes           Viaje[]          @relation("EmpresaViajes")
  pagosRecibidos   PagoDeEmpresa[]
  chequesRecibidos ChequeRecibido[]
  contactosEmail   ContactoEmail[]
  recibosCobranza  ReciboCobranza[]
  faltantesViaje   FaltanteViaje[]

  @@map("empresas")
}

model EmpresaUsuario {
  id          String @id @default(uuid())
  empresaId   String @map("empresa_id")
  usuarioId   String @map("usuario_id")
  nivelAcceso String @map("nivel_acceso")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([empresaId, usuarioId])
  @@map("empresa_usuarios")
}

// ─── FLETEROS ─────────────────────────────────────────────────────────────────

model Fletero {
  id              String  @id @default(uuid())
  usuarioId       String? @unique @map("usuario_id")
  razonSocial     String  @map("razon_social")
  cuit            String  @unique
  condicionIva    String  @map("condicion_iva")
  direccion       String? @map("direccion")
  comisionDefault Float   @map("comision_default")
  activo          Boolean @default(true)

  usuario                Usuario?           @relation("FleteroUsuario", fields: [usuarioId], references: [id])
  empleados              Empleado[]         @relation("FleteroEmpleados")
  camiones               Camion[]
  liquidaciones          Liquidacion[]
  viajes                 Viaje[]            @relation("FleteroViajes")
  pagosRecibidos         PagoAFletero[]
  chequesRecibidosEndoso ChequeRecibido[]   @relation("FleteroEndosoChequeRecibido")
  chequesEmitidos        ChequeEmitido[]    @relation("FleteroChequeEmitido")
  adelantos              AdelantoFletero[]
  gastosFletero          GastoFletero[]
  facturasPorCuenta      FacturaProveedor[] @relation("FacturaPorCuentaDeFletero")
  ordenesPago            OrdenPago[]
  contactosEmail         ContactoEmail[]
  faltantesViaje         FaltanteViaje[]

  @@map("fleteros")
}

// ─── CONTACTOS EMAIL ──────────────────────────────────────────────────────────

model ContactoEmail {
  id        String   @id @default(uuid())
  email     String
  nombre    String?
  empresaId String?  @map("empresa_id")
  fleteroId String?  @map("fletero_id")
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now()) @map("creado_en")

  empresa Empresa? @relation(fields: [empresaId], references: [id])
  fletero Fletero? @relation(fields: [fleteroId], references: [id])

  @@map("contactos_email")
}

// ─── CAMIONES ─────────────────────────────────────────────────────────────────

model Camion {
  id              String  @id @default(uuid())
  fleteroId       String? @map("fletero_id")
  esPropio        Boolean @default(false) @map("es_propio")
  patenteChasis   String  @unique @map("patente_chasis")
  patenteAcoplado String? @map("patente_acoplado")
  activo          Boolean @default(true)

  fletero         Fletero?       @relation(fields: [fleteroId], references: [id])
  choferHistorial CamionChofer[]
  viajes          Viaje[]
  polizas         PolizaSeguro[]
  infracciones    Infraccion[]   @relation("CamionInfracciones")

  @@map("camiones")
}

model PolizaSeguro {
  id              String   @id @default(uuid())
  camionId        String?  @map("camion_id")
  aseguradora     String
  nroPoliza       String   @map("nro_poliza")
  cobertura       String?
  montoMensual    Decimal? @map("monto_mensual")
  vigenciaDesde   DateTime @map("vigencia_desde")
  vigenciaHasta   DateTime @map("vigencia_hasta")
  archivos        String?
  creadoEn        DateTime @default(now()) @map("creado_en")
  tipoBien        String   @default("CAMION") @map("tipo_bien")
  proveedorId     String?  @map("proveedor_id")
  descripcionBien String?  @map("descripcion_bien")
  pdfS3Key        String?  @map("pdf_s3_key")
  activa          Boolean  @default(true)
  facturaSeguroId String?  @map("factura_seguro_id")

  camion        Camion?        @relation(fields: [camionId], references: [id], onDelete: Cascade)
  proveedor     Proveedor?     @relation(fields: [proveedorId], references: [id])
  facturaSeguro FacturaSeguro? @relation(fields: [facturaSeguroId], references: [id])

  @@map("polizas_seguro")
}

model CamionChofer {
  id       String    @id @default(uuid())
  camionId String    @map("camion_id")
  choferId String    @map("chofer_id")
  desde    DateTime
  hasta    DateTime?

  camion Camion   @relation(fields: [camionId], references: [id])
  chofer Empleado @relation("ChoferHistorial", fields: [choferId], references: [id])

  @@map("camion_chofer")
}

// ─── PAGOS DE IMPUESTOS ───────────────────────────────────────────────────────

model PagoImpuesto {
  id                  String   @id @default(uuid())
  tipoImpuesto        String   @map("tipo_impuesto")
  descripcion         String?
  periodo             String
  monto               Decimal
  fechaPago           DateTime @map("fecha_pago")
  medioPago           String   @map("medio_pago")
  cuentaId            String?  @map("cuenta_id")
  tarjetaId           String?  @map("tarjeta_id")
  comprobantePdfS3Key String?  @map("comprobante_pdf_s3_key")
  observaciones       String?
  operadorId          String   @map("operador_id")
  creadoEn            DateTime @default(now()) @map("creado_en")

  cuenta            Cuenta?            @relation("CuentaPagoImpuesto", fields: [cuentaId], references: [id])
  tarjeta           Tarjeta?           @relation("TarjetaPagoImpuesto", fields: [tarjetaId], references: [id])
  operador          Usuario            @relation("OperadorPagoImpuesto", fields: [operadorId], references: [id])
  movimientosCuenta MovimientoCuenta[]

  @@map("pagos_impuesto")
}

// ─── INFRACCIONES ─────────────────────────────────────────────────────────────

model Infraccion {
  id                  String    @id @default(uuid())
  camionId            String    @map("camion_id")
  fecha               DateTime
  organismo           String
  descripcion         String
  monto               Decimal
  estado              String    @default("PENDIENTE")
  fechaPago           DateTime? @map("fecha_pago")
  medioPago           String?   @map("medio_pago")
  cuentaId            String?   @map("cuenta_id")
  comprobantePdfS3Key String?   @map("comprobante_pdf_s3_key")
  operadorId          String    @map("operador_id")
  creadoEn            DateTime  @default(now()) @map("creado_en")

  camion            Camion             @relation("CamionInfracciones", fields: [camionId], references: [id])
  cuenta            Cuenta?            @relation("CuentaInfracciones", fields: [cuentaId], references: [id])
  operador          Usuario            @relation("OperadorInfracciones", fields: [operadorId], references: [id])
  movimientosCuenta MovimientoCuenta[]

  @@map("infracciones")
}

// ─── VIAJES (entidad base) ─────────────────────────────────────────────────────

model Viaje {
  id                     String   @id @default(uuid())
  fleteroId              String?  @map("fletero_id")
  esCamionPropio         Boolean  @default(false) @map("es_camion_propio")
  camionId               String   @map("camion_id")
  choferId               String   @map("chofer_id")
  empresaId              String   @map("empresa_id")
  operadorId             String   @map("operador_id")
  fechaViaje             DateTime @map("fecha_viaje")
  remito                 String?
  remitoS3Key            String?  @map("remito_s3_key")
  tieneCupo              Boolean  @default(false) @map("tiene_cupo")
  cupo                   String?
  mercaderia             String?
  procedencia            String?
  provinciaOrigen        String?  @map("provincia_origen")
  destino                String?
  provinciaDestino       String?  @map("provincia_destino")
  kilos                  Float?
  tarifa                 Decimal  @map("tarifa_fletero")
  tarifaEmpresa          Decimal  @map("tarifa_empresa")
  comisionPct            Float?   @map("comision_pct")
  // Campo legacy — existe en Turso con NOT NULL. Se mantiene con default para no romper inserts.
  tarifaOperativaInicial Decimal  @default(0) @map("tarifa_operativa_inicial")
  estadoLiquidacion      String   @default("PENDIENTE_LIQUIDAR") @map("estado_liquidacion")
  estadoFactura          String   @default("PENDIENTE_FACTURAR") @map("estado_factura")
  // CTG — número único + PDF en R2 (Código de Trazabilidad de Granos)
  tieneCtg               Boolean  @default(true) @map("tiene_ctg")
  nroCtg                 String?  @map("nro_ctg")
  ctgS3Key               String?  @map("ctg_s3_key")
  // CPE — número opcional asociado al CTG, sin PDF (Carta de Porte Electrónica)
  cpe                    String?
  historialCambios       String?  @default("[]") @map("historial_cambios")
  creadoEn               DateTime @default(now()) @map("creado_en")

  fletero  Fletero?  @relation("FleteroViajes", fields: [fleteroId], references: [id])
  camion   Camion    @relation(fields: [camionId], references: [id])
  chofer   Empleado  @relation("ChoferViajes", fields: [choferId], references: [id])
  empresa  Empresa   @relation("EmpresaViajes", fields: [empresaId], references: [id])
  operador Usuario   @relation("OperadorViajes", fields: [operadorId], references: [id])

  enLiquidaciones ViajeEnLiquidacion[]
  enFacturas      ViajeEnFactura[]
  viajesEnNotasCD ViajeEnNotaCD[]
  faltantes       FaltanteViaje[]

  @@index([nroCtg])
  @@map("viajes")
}

// ─── VÍNCULO VIAJE ↔ LIQUIDACIÓN ──────────────────────────────────────────────

model ViajeEnLiquidacion {
  id               String   @id @default(uuid())
  viajeId          String   @map("viaje_id")
  liquidacionId    String   @map("liquidacion_id")
  fechaViaje       DateTime @map("fecha_viaje")
  remito           String?
  cupo             String?
  mercaderia       String?
  procedencia      String?
  provinciaOrigen  String?  @map("provincia_origen")
  destino          String?
  provinciaDestino String?  @map("provincia_destino")
  kilos            Float?
  tarifaFletero    Decimal  @map("tarifa_fletero")
  subtotal         Decimal

  viaje        Viaje         @relation(fields: [viajeId], references: [id])
  liquidacion  Liquidacion   @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)
  asientosIibb AsientoIibb[]

  @@unique([viajeId, liquidacionId])
  @@map("viajes_en_liquidacion")
}

// ─── VÍNCULO VIAJE ↔ FACTURA ──────────────────────────────────────────────────

model ViajeEnFactura {
  id               String   @id @default(uuid())
  viajeId          String   @map("viaje_id")
  facturaId        String   @map("factura_id")
  fechaViaje       DateTime @map("fecha_viaje")
  remito           String?
  cupo             String?
  mercaderia       String?
  procedencia      String?
  provinciaOrigen  String?  @map("provincia_origen")
  destino          String?
  provinciaDestino String?  @map("provincia_destino")
  kilos            Float?
  tarifaEmpresa    Decimal  @map("tarifa_empresa")
  subtotal         Decimal

  viaje        Viaje          @relation(fields: [viajeId], references: [id])
  factura      FacturaEmitida @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  asientosIibb AsientoIibb[]

  @@unique([viajeId, facturaId])
  @@map("viajes_en_factura")
}

// ─── LIQUIDACIONES ────────────────────────────────────────────────────────────

model Liquidacion {
  id                String    @id @default(uuid())
  fleteroId         String    @map("fletero_id")
  operadorId        String    @map("operador_id")
  comisionPct       Float     @map("comision_pct")
  ivaPct            Float     @default(21) @map("iva_pct")
  subtotalBruto     Decimal   @map("subtotal_bruto")
  comisionMonto     Decimal   @map("comision_monto")
  neto              Decimal
  ivaMonto          Decimal   @map("iva_monto")
  total             Decimal
  estado            String    @default("EMITIDA")
  nroComprobante    Int?      @map("nro_comprobante")
  ptoVenta          Int?      @default(1) @map("pto_venta")
  tipoCbte          Int?      @default(60) @map("tipo_cbte")
  cae               String?   @map("cae")
  caeVto            DateTime? @map("cae_vto")
  qrData            String?   @map("qr_data")
  arcaEstado        String?   @default("PENDIENTE") @map("arca_estado")
  arcaObservaciones String?   @map("arca_observaciones")
  requestArcaJson   String?   @map("request_arca_json")
  // Payload enviado a ARCA (serializado como JSON string)
  responseArcaJson  String?   @map("response_arca_json")
  // Respuesta de ARCA (serializada como JSON string)
  autorizadaEn      DateTime? @map("autorizada_en")
  // Timestamp de autorización exitosa en ARCA
  idempotencyKey    String?   @map("idempotency_key")
  // UUID para prevenir doble emisión
  pdfS3Key          String?   @map("pdf_s3_key")
  grabadaEn         DateTime  @default(now()) @map("grabada_en")
  metodoPago        String    @default("Transferencia Bancaria") @map("metodo_pago")

  fletero              Fletero              @relation(fields: [fleteroId], references: [id])
  operador             Usuario              @relation("OperadorLiquidacion", fields: [operadorId], references: [id])
  viajes               ViajeEnLiquidacion[]
  pagos                PagoAFletero[]
  chequesEmitidos      ChequeEmitido[]
  adelantoDescuentos   AdelantoDescuento[]
  gastoDescuentos      GastoDescuento[]
  ncDescuentos         NCDescuento[]
  notasCreditoDebito   NotaCreditoDebito[]
  asientosIva          AsientoIva[]
  facturaEmitidaId     String?              @unique @map("factura_emitida_id")
  facturaEmitida       FacturaEmitida?      @relation("LiquidacionFactura", fields: [facturaEmitidaId], references: [id])
  faltantesDescontados FaltanteViaje[]

  @@map("liquidaciones")
}

// ─── FACTURAS EMITIDAS ────────────────────────────────────────────────────────

model FacturaEmitida {
  id                String    @id @default(uuid())
  empresaId         String    @map("empresa_id")
  operadorId        String    @map("operador_id")
  nroComprobante    String?   @map("nro_comprobante")
  tipoCbte          Int       @default(1) @map("tipo_cbte")
  // 1=Factura A, 6=Factura B, 201=Factura A MiPyme
  modalidadMiPymes  String?   @map("modalidad_mi_pymes")
  // "SCA" | "ADC" — solo para tipoCbte=201
  ivaPct            Float     @default(21) @map("iva_pct")
  neto              Decimal
  ivaMonto          Decimal   @map("iva_monto")
  total             Decimal
  ptoVenta          Int?      @default(1) @map("pto_venta")
  // Punto de venta ARCA habilitado
  cae               String?   @map("cae")
  // Código de Autorización Electrónica (14 dígitos)
  caeVto            DateTime? @map("cae_vto")
  // Fecha de vencimiento del CAE
  qrData            String?   @map("qr_data")
  // JSON base64 del QR fiscal según RG 4291
  estadoArca        String    @default("PENDIENTE") @map("estado_arca")
  arcaObservaciones String?   @map("arca_observaciones")
  // Errores o advertencias de ARCA al autorizar
  requestArcaJson   String?   @map("request_arca_json")
  // Payload enviado a ARCA (serializado como JSON string)
  responseArcaJson  String?   @map("response_arca_json")
  // Respuesta de ARCA (serializada como JSON string)
  autorizadaEn      DateTime? @map("autorizada_en")
  // Timestamp de autorización exitosa en ARCA
  idempotencyKey    String?   @map("idempotency_key")
  // UUID para prevenir doble emisión
  estado            String    @default("EMITIDA")
  pdfS3Key          String?   @map("pdf_s3_key")
  emitidaEn         DateTime  @default(now()) @map("emitida_en")
  estadoCobro       String    @default("PENDIENTE") @map("estado_cobro")
  metodoPago        String    @default("Transferencia Bancaria") @map("metodo_pago")

  empresa            Empresa             @relation(fields: [empresaId], references: [id])
  operador           Usuario             @relation("OperadorFactura", fields: [operadorId], references: [id])
  viajes             ViajeEnFactura[]
  pagos              PagoDeEmpresa[]
  asientosIva        AsientoIva[]
  chequesRecibidos   ChequeRecibido[]
  notasCreditoDebito NotaCreditoDebito[]
  enRecibos          FacturaEnRecibo[]
  liquidacion        Liquidacion?        @relation("LiquidacionFactura")

  @@map("facturas_emitidas")
}

// ─── MÓDULO FINANCIERO ────────────────────────────────────────────────────────

model Banco {
  id       String   @id @default(uuid())
  nombre   String   @unique
  activo   Boolean  @default(true)
  creadoEn DateTime @default(now()) @map("creado_en")

  cuentas Cuenta[]

  @@map("bancos")
}

model BilleteraVirtual {
  id       String   @id @default(uuid())
  nombre   String   @unique
  activa   Boolean  @default(true)
  creadoEn DateTime @default(now()) @map("creado_en")

  cuentas Cuenta[]

  @@map("billeteras_virtuales")
}

model Cuenta {
  id                            String    @id @default(uuid())
  nombre                        String    @unique
  tipo                          String
  bancoId                       String?   @map("banco_id")
  billeteraId                   String?   @map("billetera_id")
  brokerId                      String?   @map("broker_id")
  moneda                        String
  saldoInicial                  Decimal   @default(0) @map("saldo_inicial")
  fechaSaldoInicial             DateTime? @map("fecha_saldo_inicial")
  activa                        Boolean   @default(true)
  creadoEn                      DateTime  @default(now()) @map("creado_en")
  cerradaEn                     DateTime? @map("cerrada_en")
  tieneImpuestoDebcred          Boolean   @default(false) @map("tiene_impuesto_debcred")
  alicuotaImpuesto              Float     @default(0.006) @map("alicuota_impuesto")
  tieneChequera                 Boolean   @default(false) @map("tiene_chequera")
  tieneCuentaRemunerada         Boolean   @default(false) @map("tiene_cuenta_remunerada")
  tieneTarjetasPrepagasChoferes Boolean   @default(false) @map("tiene_tarjetas_prepagas_choferes")
  esCuentaComitenteBroker       Boolean   @default(false) @map("es_cuenta_comitente_broker")
  tieneIibbSircrebTucuman       Boolean   @default(false) @map("tiene_iibb_sircreb_tucuman")
  alicuotaIibbSircrebTucuman    Float     @default(0.06) @map("alicuota_iibb_sircreb_tucuman")
  nroCuenta                     String?   @map("nro_cuenta")
  cbu                           String?
  alias                         String?

  banco                       Banco?             @relation(fields: [bancoId], references: [id])
  billetera                   BilleteraVirtual?  @relation(fields: [billeteraId], references: [id])
  broker                      Broker?            @relation(fields: [brokerId], references: [id])
  fci                         Fci[]
  movimientos                 MovimientoCuenta[] @relation("CuentaMovimiento")
  movimientosComoDestino      MovimientoCuenta[] @relation("CuentaDestinoMovimiento")
  conciliacionesDia           ConciliacionDia[]
  cierresMes                  CierreMesCuenta[]
  movimientosFciOrigenDestino MovimientoFci[]    @relation("CuentaOrigenDestinoMovimientoFci")
  chequesRecibidosDepositados ChequeRecibido[]   @relation("CuentaDepositaChequeRecibido")
  chequesRecibidosBroker      ChequeRecibido[]   @relation("CuentaBrokerChequeRecibido")
  chequesEmitidos             ChequeEmitido[]    @relation("CuentaChequeEmitido")
  tarjetasPrepagas            TarjetaPrepaga[]
  tarjetas                    Tarjeta[]
  pagosProveedor              PagoProveedor[]    @relation("CuentaPagoProveedor")
  pagosAFletero               PagoAFletero[]     @relation("CuentaPagoAFletero")
  pagosDeEmpresa              PagoDeEmpresa[]    @relation("CuentaPagoDeEmpresa")
  facturasSeguro              FacturaSeguro[]    @relation("CuentaFacturaSeguro")
  pagosImpuesto               PagoImpuesto[]     @relation("CuentaPagoImpuesto")
  infracciones                Infraccion[]       @relation("CuentaInfracciones")

  @@map("cuentas")
}

// Libro unificado de movimientos por cuenta (banco / billetera / broker).
// Un MovimientoCuenta representa un débito o crédito concreto en una cuenta.
// Puede ser:
//  - MANUAL (esManual=true): ajuste, intereses, gastos de mantenimiento, etc.
//  - REFERENCIADO: ligado a una entidad (cheque, pago, movimiento FCI, etc.) vía FK nullable.
//    La regla es que como máximo UNA de las FKs está seteada.
// Para transferencias entre cuentas propias se crean 2 filas espejo con el mismo movimientoGrupoId.
model MovimientoCuenta {
  id               String   @id @default(uuid())
  cuentaId         String   @map("cuenta_id")
  fecha            DateTime @db.Date
  orden            Int // posición intra-día (1..n) para romper empates; saldo corrido respeta fecha asc, orden asc
  tipo             String // INGRESO | EGRESO
  categoria        String
  monto            Decimal // siempre positivo; el signo lo da `tipo`
  descripcion      String
  esManual         Boolean  @default(false) @map("es_manual")
  comprobanteS3Key String?  @map("comprobante_s3_key")

  // FKs nullable — a lo sumo una está seteada
  chequeEmitidoId  String? @map("cheque_emitido_id")
  chequeRecibidoId String? @map("cheque_recibido_id")
  pagoAFleteroId   String? @map("pago_a_fletero_id")
  pagoProveedorId  String? @map("pago_proveedor_id")
  pagoDeEmpresaId  String? @map("pago_de_empresa_id")
  pagoImpuestoId   String? @map("pago_impuesto_id")
  movimientoFciId  String? @map("movimiento_fci_id")
  infraccionId     String? @map("infraccion_id")

  // Transferencias entre cuentas propias (2 filas espejo)
  cuentaDestinoId   String? @map("cuenta_destino_id")
  movimientoGrupoId String? @map("movimiento_grupo_id")

  operadorCreacionId String   @map("operador_creacion_id")
  creadoEn           DateTime @default(now()) @map("creado_en")

  cuenta           Cuenta          @relation("CuentaMovimiento", fields: [cuentaId], references: [id])
  cuentaDestino    Cuenta?         @relation("CuentaDestinoMovimiento", fields: [cuentaDestinoId], references: [id], onDelete: SetNull)
  chequeEmitido    ChequeEmitido?  @relation(fields: [chequeEmitidoId], references: [id], onDelete: Cascade)
  chequeRecibido   ChequeRecibido? @relation(fields: [chequeRecibidoId], references: [id], onDelete: Cascade)
  pagoAFletero     PagoAFletero?   @relation(fields: [pagoAFleteroId], references: [id], onDelete: Cascade)
  pagoProveedor    PagoProveedor?  @relation(fields: [pagoProveedorId], references: [id], onDelete: Cascade)
  pagoDeEmpresa    PagoDeEmpresa?  @relation(fields: [pagoDeEmpresaId], references: [id], onDelete: Cascade)
  pagoImpuesto     PagoImpuesto?   @relation(fields: [pagoImpuestoId], references: [id], onDelete: Cascade)
  movimientoFci    MovimientoFci?  @relation(fields: [movimientoFciId], references: [id], onDelete: Cascade)
  infraccion       Infraccion?     @relation(fields: [infraccionId], references: [id], onDelete: Cascade)
  operadorCreacion Usuario         @relation("OperadorMovimientoCuenta", fields: [operadorCreacionId], references: [id])

  @@unique([cuentaId, fecha, orden])
  @@index([cuentaId, fecha])
  @@index([movimientoGrupoId])
  @@map("movimientos_cuenta")
}

// Sella un día (cuentaId, fecha) contra el saldo de extracto bancario.
// Si existe, los movimientos del sistema para ese día se consideran verificados.
model ConciliacionDia {
  id            String   @id @default(uuid())
  cuentaId      String   @map("cuenta_id")
  fecha         DateTime @db.Date
  saldoExtracto Decimal  @map("saldo_extracto")
  operadorId    String   @map("operador_id")
  conciliadoEn  DateTime @default(now()) @map("conciliado_en")

  cuenta   Cuenta  @relation(fields: [cuentaId], references: [id], onDelete: Cascade)
  operador Usuario @relation("OperadorConciliacionDia", fields: [operadorId], references: [id])

  @@unique([cuentaId, fecha])
  @@map("conciliaciones_dia")
}

// Cierre mensual de una cuenta. Solo se crea cuando todos los días del mes
// con movimientos tienen su ConciliacionDia. Es el sello consultado por los
// reportes contables para saber si un mes está completo.
model CierreMesCuenta {
  id             String   @id @default(uuid())
  cuentaId       String   @map("cuenta_id")
  mes            Int
  anio           Int
  operadorId     String   @map("operador_id")
  cerradoEn      DateTime @default(now()) @map("cerrado_en")
  pdfExtractoKey String?  @map("pdf_extracto_key")
  observaciones  String?

  cuenta   Cuenta  @relation(fields: [cuentaId], references: [id], onDelete: Cascade)
  operador Usuario @relation("OperadorCierreMesCuenta", fields: [operadorId], references: [id])

  @@unique([cuentaId, mes, anio])
  @@index([mes, anio])
  @@map("cierres_mes_cuenta")
}

model Fci {
  id                 String    @id @default(uuid())
  nombre             String    @unique
  cuentaId           String    @map("cuenta_id")
  moneda             String
  activo             Boolean   @default(true)
  diasHabilesAlerta  Int       @default(1) @map("dias_habiles_alerta")
  saldoActual        Decimal   @default(0) @map("saldo_actual")
  saldoActualizadoEn DateTime? @map("saldo_actualizado_en")
  creadoEn           DateTime  @default(now()) @map("creado_en")

  cuenta      Cuenta          @relation(fields: [cuentaId], references: [id])
  movimientos MovimientoFci[]
  saldos      SaldoFci[]

  @@map("fci")
}

model MovimientoFci {
  id                    String   @id @default(uuid())
  fciId                 String   @map("fci_id")
  cuentaOrigenDestinoId String   @map("cuenta_origen_destino_id")
  tipo                  String
  monto                 Decimal
  fecha                 DateTime
  descripcion           String?
  operadorId            String   @map("operador_id")
  creadoEn              DateTime @default(now()) @map("creado_en")

  fci                 Fci                @relation(fields: [fciId], references: [id], onDelete: Cascade)
  cuentaOrigenDestino Cuenta             @relation("CuentaOrigenDestinoMovimientoFci", fields: [cuentaOrigenDestinoId], references: [id])
  operador            Usuario            @relation("OperadorMovimientoFci", fields: [operadorId], references: [id])
  movimientosCuenta   MovimientoCuenta[]

  @@map("movimientos_fci")
}

model SaldoFci {
  id                 String   @id @default(uuid())
  fciId              String   @map("fci_id")
  saldoInformado     Decimal  @map("saldo_informado")
  fechaActualizacion DateTime @map("fecha_actualizacion")
  rendimientoPeriodo Decimal  @map("rendimiento_periodo")
  operadorId         String   @map("operador_id")
  creadoEn           DateTime @default(now()) @map("creado_en")

  fci      Fci     @relation(fields: [fciId], references: [id], onDelete: Cascade)
  operador Usuario @relation("OperadorSaldoFci", fields: [operadorId], references: [id])

  @@map("saldos_fci")
}

model Empleado {
  id           String   @id @default(uuid())
  usuarioId    String?  @unique @map("usuario_id")
  fleteroId    String?  @map("fletero_id")
  nombre       String
  apellido     String
  cuit         String   @unique
  cargo        String?
  // cargo: CHOFER | ADMINISTRATIVO | MECANICO | OTRO
  fechaIngreso DateTime @map("fecha_ingreso")
  activo       Boolean  @default(true)
  creadoEn     DateTime @default(now()) @map("creado_en")

  usuario Usuario? @relation("EmpleadoUsuario", fields: [usuarioId], references: [id], onDelete: SetNull)
  fletero Fletero? @relation("FleteroEmpleados", fields: [fleteroId], references: [id])

  camionesChofer        CamionChofer[]        @relation("ChoferHistorial")
  viajesChofer          Viaje[]               @relation("ChoferViajes")
  tarjetasPrepagaChofer TarjetaPrepaga[]      @relation("ChoferTarjetaPrepaga")
  tarjetasChofer        Tarjeta[]             @relation("ChoferTarjeta")

  @@map("empleados")
}

model ChequeRecibido {
  id                   String    @id @default(uuid())
  empresaId            String?   @map("empresa_id")
  brokerOrigenId       String?   @map("broker_origen_id")
  facturaId            String?   @map("factura_id")
  nroCheque            String    @map("nro_cheque")
  bancoEmisor          String    @map("banco_emisor")
  monto                Decimal
  fechaEmision         DateTime  @map("fecha_emision")
  fechaCobro           DateTime  @map("fecha_cobro")
  estado               String
  cuentaDepositoId     String?   @map("cuenta_deposito_id")
  endosadoATipo        String?   @map("endosado_a_tipo")
  endosadoAFleteroId   String?   @map("endosado_a_fletero_id")
  endosadoAProveedorId String?   @map("endosado_a_proveedor_id")
  endosadoABrokerId    String?   @map("endosado_a_broker_id")
  fechaAcreditacion    DateTime? @map("fecha_acreditacion")
  cuitLibrador         String?   @map("cuit_librador")
  tasaDescuento        Float?    @map("tasa_descuento")
  fechaDepositoBroker  DateTime? @map("fecha_deposito_broker")
  operadorId           String    @map("operador_id")
  creadoEn             DateTime  @default(now()) @map("creado_en")
  // false = cheque físico recibido de empresa cliente; true = ECheq electrónico recibido
  esElectronico        Boolean   @default(false) @map("es_electronico")
  reciboCobranzaId     String?   @map("recibo_cobranza_id")
  proveedorOrigenId    String?   @map("proveedor_origen_id")

  empresa            Empresa?            @relation(fields: [empresaId], references: [id])
  proveedorOrigen    Proveedor?          @relation("ProveedorOrigenChequeRecibido", fields: [proveedorOrigenId], references: [id])
  brokerOrigen       Broker?             @relation("BrokerOrigenChequeRecibido", fields: [brokerOrigenId], references: [id])
  factura            FacturaEmitida?     @relation(fields: [facturaId], references: [id], onDelete: SetNull)
  reciboCobranza     ReciboCobranza?     @relation("ChequesRecibo", fields: [reciboCobranzaId], references: [id], onDelete: SetNull)
  cuentaDeposito     Cuenta?             @relation("CuentaDepositaChequeRecibido", fields: [cuentaDepositoId], references: [id], onDelete: SetNull)
  endosadoAFletero   Fletero?            @relation("FleteroEndosoChequeRecibido", fields: [endosadoAFleteroId], references: [id], onDelete: SetNull)
  endosadoAProveedor Proveedor?          @relation("ProveedorEndosoChequeRecibido", fields: [endosadoAProveedorId], references: [id], onDelete: SetNull)
  endosadoABroker    Cuenta?             @relation("CuentaBrokerChequeRecibido", fields: [endosadoABrokerId], references: [id], onDelete: SetNull)
  operador           Usuario             @relation("OperadorChequeRecibido", fields: [operadorId], references: [id])
  pagosEmpresa       PagoDeEmpresa[]
  pagosFletero       PagoAFletero[]
  pagosProveedor     PagoProveedor[]     @relation("ChequeRecibidoPagoProveedor")
  adelantos          AdelantoFletero[]
  notasCreditoDebito NotaCreditoDebito[]
  movimientosCuenta  MovimientoCuenta[]

  @@map("cheques_recibidos")
}

model ChequeEmitido {
  id                  String    @id @default(uuid())
  fleteroId           String?   @map("fletero_id")
  proveedorId         String?   @map("proveedor_id")
  cuentaId            String    @map("cuenta_id")
  nroCheque           String?   @map("nro_cheque")
  tipoDocBeneficiario String    @map("tipo_doc_beneficiario")
  nroDocBeneficiario  String    @map("nro_doc_beneficiario")
  monto               Decimal
  fechaEmision        DateTime  @map("fecha_emision")
  fechaPago           DateTime  @map("fecha_pago")
  motivoPago          String    @map("motivo_pago")
  descripcion1        String?   @map("descripcion_1")
  descripcion2        String?   @map("descripcion_2")
  mailBeneficiario    String?   @map("mail_beneficiario")
  clausula            String
  estado              String    @default("PENDIENTE_EMISION")
  fechaDeposito       DateTime? @map("fecha_deposito")
  liquidacionId       String?   @map("liquidacion_id")
  operadorId          String    @map("operador_id")
  creadoEn            DateTime  @default(now()) @map("creado_en")
  // Transmagg solo emite cheques electrónicos — siempre true
  esElectronico       Boolean   @default(true) @map("es_electronico")

  fletero           Fletero?           @relation("FleteroChequeEmitido", fields: [fleteroId], references: [id], onDelete: SetNull)
  proveedor         Proveedor?         @relation("ProveedorChequeEmitido", fields: [proveedorId], references: [id], onDelete: SetNull)
  cuenta            Cuenta             @relation("CuentaChequeEmitido", fields: [cuentaId], references: [id])
  liquidacion       Liquidacion?       @relation(fields: [liquidacionId], references: [id], onDelete: SetNull)
  operador          Usuario            @relation("OperadorChequeEmitido", fields: [operadorId], references: [id])
  pagosFletero      PagoAFletero[]
  pagosProveedor    PagoProveedor[]    @relation("ChequeEmitidoPagoProveedor")
  adelantos         AdelantoFletero[]
  movimientosCuenta MovimientoCuenta[]

  @@map("cheques_emitidos")
}

model TarjetaPrepaga {
  id            String   @id @default(uuid())
  choferId      String   @map("chofer_id")
  cuentaId      String   @map("cuenta_id")
  nroTarjeta    String?  @map("nro_tarjeta")
  limiteMensual Decimal? @map("limite_mensual")
  activa        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")

  chofer Empleado              @relation("ChoferTarjetaPrepaga", fields: [choferId], references: [id])
  cuenta Cuenta                @relation(fields: [cuentaId], references: [id])
  gastos GastoTarjetaPrepaga[]

  @@map("tarjetas_prepagas")
}

model GastoTarjetaPrepaga {
  id               String   @id @default(uuid())
  tarjetaId        String   @map("tarjeta_id")
  tipoGasto        String   @map("tipo_gasto")
  monto            Decimal
  fecha            DateTime
  descripcion      String?
  comprobanteS3Key String?  @map("comprobante_s3_key")
  operadorId       String   @map("operador_id")
  creadoEn         DateTime @default(now()) @map("creado_en")

  tarjeta  TarjetaPrepaga @relation(fields: [tarjetaId], references: [id], onDelete: Cascade)
  operador Usuario        @relation("OperadorGastoTarjetaPrepaga", fields: [operadorId], references: [id])

  @@map("gastos_tarjeta_prepaga")
}

// ─── TARJETAS UNIFICADAS ───────────────────────────────────────────────────────
// tipo: CREDITO | DEBITO | PREPAGA
// titularTipo: EMPRESA | CHOFER | EMPLEADO

model Tarjeta {
  id             String   @id @default(uuid())
  nombre         String
  tipo           String
  banco          String
  ultimos4       String   @map("ultimos_4")
  titularTipo    String   @map("titular_tipo")
  titularNombre  String   @map("titular_nombre")
  cuentaId       String?  @map("cuenta_id")
  choferId       String?  @map("chofer_id")
  limiteMensual  Decimal? @map("limite_mensual")
  diaCierre      Int?     @map("dia_cierre")
  diaVencimiento Int?     @map("dia_vencimiento")
  activa         Boolean  @default(true)
  creadoEn       DateTime @default(now()) @map("creado_en")

  cuenta         Cuenta?              @relation(fields: [cuentaId], references: [id])
  chofer         Empleado?            @relation("ChoferTarjeta", fields: [choferId], references: [id])
  resumenes      ResumenTarjeta[]
  gastos         GastoTarjeta[]
  pagosProveedor PagoProveedor[]      @relation("TarjetaPagoProveedor")
  facturasSeguro FacturaSeguro[]      @relation("TarjetaFacturaSeguro")
  cuotasSeguro   CuotaFacturaSeguro[] @relation("TarjetaCuotasSeguro")
  pagosImpuesto  PagoImpuesto[]       @relation("TarjetaPagoImpuesto")

  @@map("tarjetas")
}

model ResumenTarjeta {
  id           String    @id @default(uuid())
  tarjetaId    String    @map("tarjeta_id")
  periodo      String
  periodoDesde DateTime? @map("periodo_desde")
  periodoHasta DateTime? @map("periodo_hasta")
  fechaVtoPago DateTime  @map("fecha_vto_pago")
  totalARS     Decimal   @map("total_ars")
  totalUSD     Decimal?  @map("total_usd")
  s3Key        String?   @map("s3_key")
  pagado       Boolean   @default(false)
  estado       String    @default("PENDIENTE")
  conciliadoEn DateTime? @map("conciliado_en")
  operadorId   String?   @map("operador_id")
  creadoEn     DateTime  @default(now()) @map("creado_en")

  tarjeta         Tarjeta                  @relation(fields: [tarjetaId], references: [id], onDelete: Cascade)
  pagosProveedor  PagoProveedor[]          @relation("ResumenTarjetaPagoProveedor")
  cuotasSeguro    CuotaFacturaSeguro[]     @relation("ResumenCuotasSeguro")
  operador        Usuario?                 @relation("OperadorResumenTarjeta", fields: [operadorId], references: [id])
  diasConciliados ConciliacionDiaTarjeta[]

  @@map("resumenes_tarjeta")
}

model ConciliacionDiaTarjeta {
  id               String   @id @default(uuid())
  resumenTarjetaId String   @map("resumen_tarjeta_id")
  fecha            DateTime
  saldoResumen     Decimal  @map("saldo_resumen")
  conciliadoEn     DateTime @default(now()) @map("conciliado_en")
  operadorId       String   @map("operador_id")

  resumen  ResumenTarjeta @relation(fields: [resumenTarjetaId], references: [id], onDelete: Cascade)
  operador Usuario        @relation("OperadorConciliacionDiaTarjeta", fields: [operadorId], references: [id])

  @@unique([resumenTarjetaId, fecha])
  @@map("conciliacion_dia_tarjeta")
}

model GastoTarjeta {
  id               String   @id @default(uuid())
  tarjetaId        String   @map("tarjeta_id")
  tipoGasto        String   @map("tipo_gasto")
  monto            Decimal
  fecha            DateTime
  descripcion      String?
  comprobanteS3Key String?  @map("comprobante_s3_key")
