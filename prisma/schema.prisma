  facturaSeguroId     String?   @map("factura_seguro_id")
  montoPagado         Decimal     @map("monto_pagado")
  creadoEn            DateTime  @default(now()) @map("creado_en")

  cierreResumen       CierreResumenTarjeta  @relation(fields: [cierreResumenId], references: [id])
  facturaProveedor    FacturaProveedor?     @relation("PagoTarjetaFacturaProveedor", fields: [facturaProveedorId], references: [id])
  facturaSeguro       FacturaSeguro?        @relation("PagoTarjetaFacturaSeguro", fields: [facturaSeguroId], references: [id])

  @@map("pagos_factura_tarjeta")
}

// ─── HISTORIAL DE PAGOS ───────────────────────────────────────────────────────
// tipoEvento: CREACION | MODIFICACION | ANULACION

// ─── CONFIGURACIÓN ARCA ───────────────────────────────────────────────────────

model ConfiguracionArca {
  id               String   @id @default("unico")
  cuit             String   @default("30709381683")
  razonSocial      String   @default("") @map("razon_social")
  certificadoB64   String?  @map("certificado_b64")
  certificadoPass  String?  @map("certificado_pass")
  modo             String   @default("homologacion")
  puntosVenta              String   @default("{}") @map("puntos_venta")
  comprobantesHabilitados  String   @default("[]") @map("comprobantes_habilitados")
  cbuMiPymes               String?  @map("cbu_mi_pymes")
  activa                   Boolean  @default(false)
  logoComprobanteB64       String?  @map("logo_comprobante_b64")
  logoArcaB64              String?  @map("logo_arca_b64")
  logoComprobanteR2Key     String?  @map("logo_comprobante_r2_key")
  logoArcaR2Key            String?  @map("logo_arca_r2_key")
  actualizadoEn            DateTime @updatedAt @map("actualizado_en")
  actualizadoPor           String?  @map("actualizado_por")

  @@map("configuracion_arca")
}

// Cache del ticket de acceso WSAA para evitar autenticar en cada request.
// El ticket dura 12 horas; se renueva automáticamente al expirar.
model TicketWsaa {
  id          String   @id @default("wsfe")
  // "wsfe" para WSFEv1. Extensible a otros servicios si se necesita.
  token       String
  sign        String
  expiresAt   DateTime @map("expires_at")
  // Momento de expiración del ticket (generationTime + 12h de WSAA)
  obtainedAt  DateTime @default(now()) @map("obtained_at")
  // Momento en que se obtuvo este ticket

  @@map("tickets_wsaa")
}

model HistorialPago {
  id                String    @id @default(uuid())
  pagoFleteroId     String?   @map("pago_fletero_id")
  pagoProveedorId   String?   @map("pago_proveedor_id")
  tipoEvento        String    @map("tipo_evento")   // CREACION | MODIFICACION | ANULACION
  justificacion     String
  estadoAnterior    String?   @map("estado_anterior") // JSON con los campos que cambiaron
  operadorId        String    @map("operador_id")
  creadoEn          DateTime  @default(now()) @map("creado_en")

  pagoFletero   PagoAFletero?  @relation(fields: [pagoFleteroId], references: [id])
  pagoProveedor PagoProveedor? @relation(fields: [pagoProveedorId], references: [id])
  operador      Usuario        @relation("OperadorHistorialPago", fields: [operadorId], references: [id])

  @@map("historial_pagos")
}

// ─── RECIBOS DE COBRANZA ──────────────────────────────────────────────────────

model ReciboCobranza {
  id                 String    @id @default(uuid())
  nro                Int
  ptoVenta           Int       @default(1) @map("pto_venta")
  fecha              DateTime  @default(now())
  empresaId          String    @map("empresa_id")
  totalCobrado       Decimal     @map("total_cobrado")
  totalRetenciones   Decimal     @default(0) @map("total_retenciones")
  totalComprobantes  Decimal     @map("total_comprobantes")
  retencionGanancias Decimal     @default(0) @map("retencion_ganancias")
  retencionIIBB      Decimal     @default(0) @map("retencion_iibb")
  retencionSUSS      Decimal     @default(0) @map("retencion_suss")
  pdfS3Key           String?   @map("pdf_s3_key")
  operadorId         String    @map("operador_id")
  creadoEn           DateTime  @default(now()) @map("creado_en")

  empresa           Empresa           @relation(fields: [empresaId], references: [id])
  operador          Usuario           @relation("OperadorRecibo", fields: [operadorId], references: [id])
  facturas          FacturaEmitida[]  @relation("FacturasRecibo")
  mediosPago        MedioPagoRecibo[]
  chequesRecibidos  ChequeRecibido[]  @relation("ChequesRecibo")

  @@map("recibos_cobranza")
}

model MedioPagoRecibo {
  id                 String    @id @default(uuid())
  reciboId           String    @map("recibo_id")
  tipo               String    // TRANSFERENCIA | ECHEQ | CHEQUE_FISICO
  monto              Decimal
  cuentaId           String?   @map("cuenta_id")
  fechaTransferencia DateTime? @map("fecha_transferencia")
  referencia         String?
  nroCheque          String?   @map("nro_cheque")
  bancoEmisor        String?   @map("banco_emisor")
  fechaEmision       DateTime? @map("fecha_emision")
  fechaPago          DateTime? @map("fecha_pago")

  recibo   ReciboCobranza @relation(fields: [reciboId], references: [id])

  @@map("medios_pago_recibo")
}

// ─── CONFIGURACIÓN OTP ────────────────────────────────────────────────────────

model ConfiguracionOtp {
  id              String   @id @default("singleton")
  host            String?
  puerto          Int?
  usuario         String?
  passwordHash    String?  @map("password_hash")
  usarSsl         Boolean  @default(true) @map("usar_ssl")
  emailRemitente  String?  @map("email_remitente")
  nombreRemitente String?  @map("nombre_remitente")
  activo          Boolean  @default(false)
  actualizadoEn   DateTime @updatedAt @map("actualizado_en")

  @@map("configuracion_otp")
}
