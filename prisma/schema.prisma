model MovimientoSinFactura {
  id               String   @id @default(uuid())
  cuentaId         String   @map("cuenta_id")
  tipo             String   // INGRESO | EGRESO
  categoria        String   // CHEQUE_DEPOSITADO | CHEQUE_EMITIDO_DEBITADO | TRANSFERENCIA_RECIBIDA | TRANSFERENCIA_ENVIADA | TRANSFERENCIA_ENTRE_CUENTAS_PROPIAS | ENVIO_A_BROKER | RESCATE_DE_BROKER | INTERES_CUENTA_REMUNERADA | PAGO_SERVICIO | MANTENIMIENTO_CUENTA | PAGO_TARJETA | DESCUENTO_CHEQUE_BANCO | PAGO_SUELDO | OTRO
  monto            Decimal    // siempre positivo
  fecha            DateTime
  descripcion      String
  referencia       String?
  comprobanteS3Key String?  @map("comprobante_s3_key")
  cuentaDestinoId  String?  @map("cuenta_destino_id")
  tarjetaId        String?  @map("tarjeta_id")
  operadorId       String   @map("operador_id")
  creadoEn         DateTime @default(now()) @map("creado_en")

