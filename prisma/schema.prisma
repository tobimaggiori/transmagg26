// ─── PROVEEDORES ──────────────────────────────────────────────────────────────

model Proveedor {
  id           String  @id @default(uuid())
  razonSocial  String  @map("razon_social")
  cuit         String  @unique
  condicionIva String  @map("condicion_iva")
  rubro        String?
  tipo         String  @default("GENERAL")
  activo       Boolean @default(true)

  facturas               FacturaProveedor[]
  chequesRecibidosOrigen ChequeRecibido[]  @relation("ProveedorOrigenChequeRecibido")
  chequesRecibidosEndoso ChequeRecibido[]  @relation("ProveedorEndosoChequeRecibido")
  chequesEmitidos        ChequeEmitido[]   @relation("ProveedorChequeEmitido")
  polizas                PolizaSeguro[]
  facturasSeguro         FacturaSeguro[]   @relation("AseguradoraFacturasSeguro")

  @@map("proveedores")
}

model FacturaProveedor {
  id                   String   @id @default(uuid())
  proveedorId          String   @map("proveedor_id")
  nroComprobante       String   @map("nro_comprobante")
  ptoVenta             String?  @map("pto_venta")
  tipoCbte             String   @map("tipo_cbte")
  neto                 Decimal
  ivaMonto             Decimal    @map("iva_monto")
  total                Decimal
  fechaCbte            DateTime @map("fecha_cbte")
  concepto             String?  @map("concepto")
  pdfS3Key             String?  @map("pdf_s3_key")
  estadoPago           String   @default("PENDIENTE") @map("estado_pago")
  percepcionIIBB       Decimal?   @map("percepcion_iibb")
  percepcionIVA        Decimal?   @map("percepcion_iva")
  percepcionGanancias  Decimal?   @map("percepcion_ganancias")
  // Gasto por cuenta de fletero: la factura es del fletero, Transmagg la paga
  esPorCuentaDeFletero Boolean  @default(false) @map("es_por_cuenta_de_fletero")
  fleteroId            String?  @map("fletero_id")
  tipoGastoFletero     String?  @map("tipo_gasto_fletero")  // COMBUSTIBLE | OTRO

  proveedor    Proveedor              @relation(fields: [proveedorId], references: [id])
  fletero      Fletero?               @relation("FacturaPorCuentaDeFletero", fields: [fleteroId], references: [id])
  pagos        PagoProveedor[]
  asientosIva  AsientoIva[]
  items        ItemFacturaProveedor[]
  gastoFletero       GastoFletero?
  pagosTarjeta       PagoFacturaTarjeta[] @relation("PagoTarjetaFacturaProveedor")
  percepciones       PercepcionImpuesto[]

  @@map("facturas_proveedor")
}

model ItemFacturaProveedor {
  id                 String   @id @default(uuid())
  facturaProveedorId String   @map("factura_proveedor_id")
  descripcion        String
  cantidad           Float    @default(1)
  precioUnitario     Decimal    @map("precio_unitario")
  alicuotaIva        Float    @map("alicuota_iva")
  esExento           Boolean  @default(false) @map("es_exento")
  subtotalNeto       Decimal    @map("subtotal_neto")
  montoIva           Decimal    @map("monto_iva")
  subtotalTotal      Decimal    @map("subtotal_total")

  facturaProveedor FacturaProveedor @relation(fields: [facturaProveedorId], references: [id], onDelete: Cascade)

  @@map("items_factura_proveedor")
}

// TipoPagoProveedor: TRANSFERENCIA | CHEQUE_PROPIO | CHEQUE_FISICO_TERCERO | CHEQUE_ELECTRONICO_TERCERO | TARJETA | EFECTIVO
model PagoProveedor {
  id                  String    @id @default(uuid())
  facturaProveedorId  String    @map("factura_proveedor_id")
  fecha               DateTime
  monto               Decimal
  tipo                String
  observaciones       String?
  comprobantePdfS3Key String?   @map("comprobante_pdf_s3_key")
  cuentaId            String?   @map("cuenta_id")
  chequeRecibidoId    String?   @map("cheque_recibido_id")
  chequeEmitidoId     String?   @map("cheque_emitido_id")
  tarjetaId           String?   @map("tarjeta_id")
  resumenTarjetaId    String?   @map("resumen_tarjeta_id")
  operadorId          String?   @map("operador_id")
  creadoEn            DateTime  @default(now()) @map("creado_en")
  anulado             Boolean   @default(false)
  motivoAnulacion     String?   @map("motivo_anulacion")

  facturaProveedor  FacturaProveedor @relation(fields: [facturaProveedorId], references: [id])
  cuenta            Cuenta?          @relation("CuentaPagoProveedor", fields: [cuentaId], references: [id])
  chequeRecibido    ChequeRecibido?  @relation("ChequeRecibidoPagoProveedor", fields: [chequeRecibidoId], references: [id])
  chequeEmitido     ChequeEmitido?   @relation("ChequeEmitidoPagoProveedor", fields: [chequeEmitidoId], references: [id])
  tarjeta           Tarjeta?         @relation("TarjetaPagoProveedor", fields: [tarjetaId], references: [id])
  resumenTarjeta    ResumenTarjeta?  @relation("ResumenTarjetaPagoProveedor", fields: [resumenTarjetaId], references: [id])
  operador          Usuario?         @relation("OperadorPagoProveedor", fields: [operadorId], references: [id])
  historial         HistorialPago[]

  @@map("pagos_proveedor")
}

