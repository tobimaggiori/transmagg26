# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:password@localhost:5432/transmagg"

# NextAuth
NEXTAUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Encriptacion de contrasenas SMTP (AES-256-GCM)
# Generar con: openssl rand -hex 32
ENCRYPTION_KEY=""

# Resend (envio de emails OTP)
RESEND_API_KEY=""

# Cloudflare R2 (almacenamiento de PDFs y comprobantes)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=transmagg
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
