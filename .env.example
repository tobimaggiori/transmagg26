# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:password@localhost:5432/transmagg"

# NextAuth
NEXTAUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Encriptación de contraseñas SMTP (AES-256-GCM)
# Generar con: openssl rand -hex 32
ENCRYPTION_KEY="your-64-char-hex-encryption-key-here-generate-with-openssl-rand-hex-32"

# Email (SMTP) - usar Ethereal.email para desarrollo
EMAIL_SERVER_HOST="smtp.ethereal.email"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="test@ethereal.email"
EMAIL_SERVER_PASSWORD="testpassword"
EMAIL_FROM="noreply@transmagg.com.ar"

# O usar EMAIL_SERVER como URL completa:
# EMAIL_SERVER=smtp://user:pass@smtp.example.com:587

# Cloudflare R2 (almacenamiento de PDFs y comprobantes)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=transmagg
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# ARCA (AFIP) - configuración de integración fiscal
# Estos valores también se gestionan desde /abm?tab=arca en la UI.
# Las credenciales del certificado se almacenan en la base de datos (no en .env).
# ARCA_MODO="homologacion"   # o "produccion"
# ARCA_WSAA_URL_HOMO="https://wsaahomo.afip.gov.ar/ws/services/LoginCms"
# ARCA_WSAA_URL_PROD="https://wsaa.afip.gov.ar/ws/services/LoginCms"
# ARCA_WSFEV1_URL_HOMO="https://wswhomo.afip.gov.ar/wsfev1/service.asmx"
# ARCA_WSFEV1_URL_PROD="https://servicios1.afip.gov.ar/wsfev1/service.asmx"
