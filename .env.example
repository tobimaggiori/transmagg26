# Base de datos SQLite
DATABASE_URL="file:./prisma/dev.db"

# NextAuth
NEXTAUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Email (SMTP) - usar Ethereal.email para desarrollo
EMAIL_SERVER_HOST="smtp.ethereal.email"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="test@ethereal.email"
EMAIL_SERVER_PASSWORD="testpassword"
EMAIL_FROM="noreply@transmagg.com.ar"

# O usar EMAIL_SERVER como URL completa:
# EMAIL_SERVER=smtp://user:pass@smtp.example.com:587

# AWS S3 (opcional, para almacenar PDFs)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=transmagg-docs
