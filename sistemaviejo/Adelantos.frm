    Set Lista = CHTerAplic.ListItems.Add(, , x.Tag)
    Lista.Tag = x.Tag
    Lista.SubItems(1) = x.SubItems(1)
    Lista.SubItems(2) = x.SubItems(2)
    Lista.SubItems(3) = x.SubItems(3)
    TCHTer = TCHTer + x.SubItems(3)
