Private Sub VScroll1_Change()
If VALOR <= VScroll1.Value Then
    i = 0
    For i = i + 1 To Text4.Count
         Text4(i - 1).Top = Text4(i - 1).Top - (VScroll1.Value)
    Next
ElseIf VALOR = 0 Then
    i = 0
    For i = i + 1 To Text4.Count
         Text4(i - 1).Top = 240
    Next
Else
    i = 0
    For i = i + 1 To Text4.Count
         Text4(i - 1).Top = Text4(i - 1).Top + (VScroll1.Value)
    Next
End If
VALOR = VScroll1.Value
End Sub

