Private Sub Buscar()
If OpCons = "Fletero" Then
     With BuscFlet
        .Show
        .Height = 6015
        .Width = 6225
        .Top = (Screen.Height - .Height) / 2
        .Left = (Screen.Width - .Width) / 2
        .Viene = "FactProv"
    End With
End If
If OpCons = "Concepto" Then
     With BuscConcCompras
        .Show
        .Height = 6015
        .Width = 6105
        .Top = (Screen.Height - .Height) / 2
        .Left = (Screen.Width - .Width) / 2
        .Viene(0) = "FactProv"
        .Viene(1) = Item
    End With
End If

End Sub
Private Sub Form_Load()
Comp.Clear
Comp.AddItem ("Factura")
Comp.AddItem ("Nota de Debito")
Comp.AddItem ("Nota de Credito")
Comp.ListIndex = 0
i = 0
For i = i + 1 To Text1.Count
    If i > 57 Then
        Text1(i - 1) = "0.00"
    ElseIf i = 10 Or i = 16 Or i = 22 Or i = 28 Or i = 34 Or i = 40 Or i = 46 Or i = 52 Or i = 53 Or i = 54 Or i = 55 Then
        Text1(i - 1) = "0.00"
    ElseIf i = 9 Or i = 15 Or i = 21 Or i = 27 Or i = 33 Or i = 39 Or i = 45 Or i = 51 Then
        Text1(i - 1) = "0.00"
    ElseIf i = 8 Or i = 14 Or i = 20 Or i = 26 Or i = 32 Or i = 38 Or i = 44 Or i = 50 Then
        Text1(i - 1) = "0.00"
    ElseIf i = 7 Or i = 13 Or i = 19 Or i = 25 Or i = 31 Or i = 37 Or i = 43 Or i = 49 Then
        Text1(i - 1) = "0.00"
    ElseIf i = 56 Or i = 57 Then
        Text1(i - 1) = ""
    Else
        Text1(i - 1) = ""
    End If
Next
Fecha = Date
TFact = 0: TIVAFact = 0: TNetoFact = 0
PFact = 0: PIVA = 0: PNeto = 0
UnitNeto = 0: UnitIVA = 0
End Sub

Private Sub Text1_GotFocus(Index As Integer)
i = Index
If i = 2 Then
    OpCons = "Fletero"
End If
If i = 4 Or i = 10 Or i = 16 Or i = 22 Or i = 28 Or i = 34 Or i = 40 Or i = 46 Then
    OpCons = "Concepto"
    If Not Text1(i) = "" Then
    CodConcepto = Text1(i)
    End If
    Item = i
End If
If i = 8 Or i = 14 Or i = 20 Or i = 26 Or i = 32 Or i = 38 Or i = 45 Or i = 50 Then
    x = Len(Text1(Index))
    Text1(Index).SelStart = 0
    Text1(Index).SelLength = x
    PIVA = (Text1(Index) * Text1(Index - 1)) * Text1(Index - 2) / 100
    
    PNeto = Text1(Index) * Text1(Index - 1)
    
ElseIf i = 7 Or i = 13 Or i = 19 Or i = 25 Or i = 31 Or i = 37 Or i = 43 Or i = 49 Then
    x = Len(Text1(Index))
    Text1(Index).SelStart = 0
    Text1(Index).SelLength = x
    PIVA = (Text1(Index) * Text1(Index + 1)) * Text1(Index - 1) / 100
    
    PNeto = Text1(Index) * Text1(Index + 1)
    
ElseIf i = 6 Or i = 12 Or i = 18 Or i = 24 Or i = 30 Or i = 36 Or i = 42 Or i = 48 Then
    x = Len(Text1(Index))
    Text1(Index).SelStart = 0
    Text1(Index).SelLength = x
    PIVA = (Text1(Index + 1) * Text1(Index + 2)) * Text1(Index) / 100
    
    PNeto = Text1(Index + 1) * Text1(Index + 2)
End If
End Sub

Private Sub Text1_LostFocus(Index As Integer)
Select Case Index
Case 0:
    VTamańo = Len(Text1(0))
    Select Case VTamańo
        Case 1: Text1(0) = "000" & Text1(0)
        Case 2: Text1(0) = "00" & Text1(0)
        Case 3: Text1(0) = "0" & Text1(0)
        Case 4: Text1(0) = Text1(0)
    End Select
Case 1:
    VTamańo = Len(Text1(1))
    Select Case VTamańo
        Case 1: Text1(1) = "0000000" & Text1(1)
        Case 2: Text1(1) = "000000" & Text1(1)
        Case 3: Text1(1) = "00000" & Text1(1)
        Case 4: Text1(1) = "0000" & Text1(1)
        Case 5: Text1(1) = "000" & Text1(1)
        Case 6: Text1(1) = "00" & Text1(1)
        Case 7: Text1(1) = "0" & Text1(1)
        Case 8: Text1(1) = Text1(1)
    End Select
Case 2:
    If Not Text1(2) = "" Then
        Set rsFleteros = db.OpenRecordset("Select * From Fleteros Where CodFlet = " & Text1(2) & " and TipoProv = 0")
        If Not rsFleteros.EOF And Not rsFleteros.BOF Then
            Text1(3) = rsFleteros!DescFlet
        Else
            MsgBox "El código no pertenece a un fletero", vbInformation
            Text1(2) = "": Text1(3) = ""
        End If
        Set rsFleteros = Nothing
    End If
Case 55:
    If Not Text1(55) = "" Then
        Set rsFleteros = db.OpenRecordset("Select * From Fleteros Where CodFlet = " & Text1(55) & " and TipoProv = 1")
        If Not rsFleteros.EOF And Not rsFleteros.BOF Then
            Text1(56) = rsFleteros!DescFlet
        Else
            MsgBox "El código no pertenece a un proveedor", vbInformation
            Text1(55) = "": Text1(56) = ""
        End If
        Set rsFleteros = Nothing
    End If

Case 4, 10, 16, 22, 28, 34, 40, 46:
    A = 4
    For A = 4 To 46 Step 6
        If Not A = Index Then
        If Text1(A) = Text1(Index) Then
            MsgBox "No puede repetir el concepto"
            Exit Sub
        End If
        End If
    Next
    If Not Text1(Index) = "" Then
        Set rsConceptoCompras = db.OpenRecordset("Select * From ConceptoCompras Where CodConcepto = " & Text1(Index) & "")
        If Not rsConceptoCompras.EOF And Not rsConceptoCompras.BOF Then
            Text1(Index + 1) = rsConceptoCompras!descconcepto
            CodConcepto = Text1(Index)
        End If
        Set rsConceptoCompras = Nothing
    End If
Case 6, 12, 18, 24, 30, 36, 42, 48:
    If Not IsNumeric(Text1(Index)) Then
        MsgBox "El campo debe ser numerico", vbInformation
        Text1(Index) = "": Text1(Index).SetFocus
    Else
        Text1(Index) = FormatNumber(Text1(Index))
        UnitNeto = Text1(Index + 1) * Text1(Index + 2)
        UnitIVA = (Text1(Index + 1) * Text1(Index + 2)) * Text1(Index) / 100
        Text1(Index + 3) = FormatNumber(UnitNeto)
        If Not Not CodConcepto = 14 And Not CodConcepto = 16 And Not CodConcepto = 17 And Not CodConcepto = 18 And Not CodConcepto = 20 Then
            TNetoFact = TNetoFact - PNeto + UnitNeto
            TIVAFact = TIVAFact - PIVA + UnitIVA
            TFact = TFact - PIVA - PNeto + UnitNeto + UnitIVA
        ElseIf CodConcepto = 14 Then
            Text1(58) = FormatNumber(Text1(58) + UnitNeto)
            TFact = TFact - PNeto + UnitNeto
        ElseIf CodConcepto = 16 Then
            Text1(57) = FormatNumber(Text1(57) + UnitNeto)
            TFact = TFact - PNeto + UnitNeto
        ElseIf CodConcepto = 17 Or CodConcepto = 20 Then
            Text1(60) = FormatNumber(Text1(60) + UnitNeto)
            TFact = TFact - PNeto + UnitNeto
        ElseIf CodConcepto = 18 Then
            Text1(59) = FormatNumber(Text1(59) + UnitNeto)
            TFact = TFact - PNeto + UnitNeto
        End If
        Text1(52) = FormatNumber(TNetoFact)
        Text1(53) = FormatNumber(TIVAFact)
        Text1(54) = FormatNumber(TFact)
    End If
Case 7, 13, 19, 25, 31, 37, 43, 49:
    If Not IsNumeric(Text1(Index)) Then
        MsgBox "El campo debe ser numerico", vbInformation
        Text1(Index) = "": Text1(Index).SetFocus
    Else
        Text1(Index) = FormatNumber(Text1(Index))
        
        UnitNeto = Text1(Index) * Text1(Index + 1)
        UnitIVA = (Text1(Index) * Text1(Index + 1)) * Text1(Index - 1) / 100
        Text1(Index + 2) = FormatNumber(UnitNeto)
        If Not CodConcepto = 14 And Not CodConcepto = 16 And Not CodConcepto = 17 And Not CodConcepto = 18 And Not CodConcepto = 20 Then
            TNetoFact = TNetoFact - PNeto + UnitNeto
            TIVAFact = TIVAFact - PIVA + UnitIVA
            TFact = TFact - PIVA - PNeto + UnitNeto + UnitIVA
        ElseIf CodConcepto = 14 Then
            Text1(58) = FormatNumber(Text1(58) + UnitNeto)
            TFact = TFact - PNeto + UnitNeto
        ElseIf CodConcepto = 16 Then
            Text1(57) = FormatNumber(Text1(57) + UnitNeto)
            TFact = TFact - PNeto + UnitNeto
        ElseIf CodConcepto = 17 Or CodConcepto = 20 Then
            Text1(60) = FormatNumber(Text1(60) + UnitNeto)
            TFact = TFact - PNeto + UnitNeto
        ElseIf CodConcepto = 18 Then
            Text1(59) = FormatNumber(Text1(59) + UnitNeto)
            TFact = TFact - PNeto + UnitNeto
        End If
        Text1(52) = FormatNumber(TNetoFact)
        Text1(53) = FormatNumber(TIVAFact)
        Text1(54) = FormatNumber(TFact)
        
    End If
Case 8, 14, 20, 26, 32, 38, 44, 50:
    If Not IsNumeric(Text1(Index)) Then
        MsgBox "El campo debe ser numerico", vbInformation
        Text1(Index) = "": Text1(Index).SetFocus
    Else
        Text1(Index) = FormatNumber(Text1(Index))
        
        UnitNeto = Text1(Index) * Text1(Index - 1)
        UnitIVA = (Text1(Index) * Text1(Index - 1)) * Text1(Index - 2) / 100
        Text1(Index + 1) = FormatNumber(UnitNeto)
        If Not CodConcepto = 14 And Not CodConcepto = 16 And Not CodConcepto = 17 And Not CodConcepto = 18 And Not CodConcepto = 20 Then
            TNetoFact = TNetoFact - PNeto + UnitNeto
            TIVAFact = TIVAFact - PIVA + UnitIVA
            TFact = TFact - PIVA - PNeto + UnitNeto + UnitIVA
        ElseIf CodConcepto = 14 Then
            Text1(58) = FormatNumber(Text1(58) + UnitNeto)
            TFact = TFact - PNeto + UnitNeto
        ElseIf CodConcepto = 16 Then
            Text1(57) = FormatNumber(Text1(57) + UnitNeto)
            TFact = TFact - PNeto + UnitNeto
        ElseIf CodConcepto = 17 Or CodConcepto = 20 Then
            Text1(60) = FormatNumber(Text1(60) + UnitNeto)
            TFact = TFact - PNeto + UnitNeto
        ElseIf CodConcepto = 18 Then
            Text1(59) = FormatNumber(Text1(59) + UnitNeto)
            TFact = TFact - PNeto + UnitNeto
        End If
        Text1(52) = FormatNumber(TNetoFact)
        Text1(53) = FormatNumber(TIVAFact)
        Text1(54) = FormatNumber(TFact)
        
    End If

End Select
End Sub




